// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// enum for stages
enum Stage {
  planted
  growing
  ready
  harvested
}

enum FieldStatus {
  active
  atRisk
  completed
}

// Models
//role
model Role {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  users     User[]

  @@map("roles")
}

// user
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())

  // relation with role
  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  // relation with field one user can have many fields
  fields Field[]

  // relation with field update one user can have many updates
  updates FieldUpdate[]

  @@map("users")
}

// field
model Field {
  id           String   @id @default(uuid())
  name         String
  cropType     String
  plantingDate DateTime
  currentStage Stage
  status       FieldStatus
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  agentId String? //foreing key from the user table
  agent   User?   @relation(fields: [agentId], references: [id])

  // relation with fieldUpdate one field can have many updates
  updates FieldUpdate[]

  @@map("fields")
}

model FieldUpdate {
  id String @id @default(uuid())

  fieldId String
  field   Field  @relation(fields: [fieldId], references: [id])

  agentId String
  agent   User   @relation(fields: [agentId], references: [id])

  stage     Stage
  notes     String?
  createdAt DateTime @default(now())

  @@map("field_updates")
}
